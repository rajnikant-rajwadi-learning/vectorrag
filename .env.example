# ---------------------------------------------------------------------------
# Copy to ".env" and fill in. NEVER commit the real .env file.
# In AWS the key is read from Secrets Manager, not from this file.
# ---------------------------------------------------------------------------

# --- OpenAI ---
OPENAI_API_KEY=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
VECTORRAG_CHAT_MODEL=gpt-4o-mini
VECTORRAG_EMBEDDING_MODEL=text-embedding-3-small

# --- Generation controls (anti-hallucination) ---
VECTORRAG_TEMPERATURE=0.0
VECTORRAG_MAX_OUTPUT_TOKENS=800

# --- Retrieval / token budget ---
VECTORRAG_TOP_K=5
VECTORRAG_CHUNK_SIZE_TOKENS=500
VECTORRAG_CHUNK_OVERLAP_TOKENS=80
VECTORRAG_MAX_CONTEXT_TOKENS=6000
VECTORRAG_MIN_RELEVANCE_SCORE=0.20

# --- Vector store (Chroma) ---
VECTORRAG_CHROMA_DIR=./.chroma
VECTORRAG_COLLECTION=tenq_filings

# --- Conversation memory ---
VECTORRAG_MAX_HISTORY_TOKENS=2000

# --- AWS (Lambda only) ---
# When set, the API key is loaded from this Secrets Manager secret instead of OPENAI_API_KEY.
VECTORRAG_OPENAI_SECRET_NAME=
AWS_REGION=us-east-1
